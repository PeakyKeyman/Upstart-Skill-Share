          {
            "type": "command",
            "command": "node \"/Users/cian/.claude/hooks/safety-guard.js\""
          },
          {
            "type": "command",
            "command": "node \"/Users/cian/.claude/hooks/commit-guard.js\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
