          {
            "type": "command",
            "command": "node \"/Users/cian/.claude/hooks/file-size-guard.js\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/cian/.claude/hooks/read-guard.js\""
          }
        ]
      }
